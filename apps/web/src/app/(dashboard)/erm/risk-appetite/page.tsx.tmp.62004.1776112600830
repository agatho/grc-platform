"use client";

import { useCallback, useEffect, useState } from "react";
import { useTranslations } from "next-intl";
import {
  Loader2,
  RefreshCcw,
  AlertTriangle,
  CheckCircle2,
  TrendingUp,
  TrendingDown,
} from "lucide-react";

import { ModuleGate } from "@/components/module/module-gate";
import { ModuleTabNav } from "@/components/layout/module-tab-nav";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";

interface DashboardItem {
  category: string;
  avgResidual: number;
  maxResidual: number;
  appetiteThreshold: number;
  riskCount: number;
  breachCount: number;
  isBreached: boolean;
}

interface Breach {
  riskId: string;
  riskTitle: string;
  riskCategory: string;
  residualScore: number;
  appetiteThreshold: number;
  delta: number;
  ownerName?: string | null;
}

interface DashboardSummary {
  categoriesWithinAppetite: number;
  totalCategories: number;
}

export default function RiskAppetitePage() {
  return (
    <ModuleGate moduleKey="erm">
      <ModuleTabNav />
      <RiskAppetiteInner />
    </ModuleGate>
  );
}

function RiskAppetiteInner() {
  const t = useTranslations("boardKpi");
  const [dashboard, setDashboard] = useState<DashboardItem[]>([]);
  const [summary, setSummary] = useState<DashboardSummary | null>(null);
  const [breaches, setBreaches] = useState<Breach[]>([]);
  const [loading, setLoading] = useState(true);

  const fetchData = useCallback(async () => {
    setLoading(true);
    try {
      const [dashRes, breachRes] = await Promise.all([
        fetch("/api/v1/erm/risk-appetite/dashboard"),
        fetch("/api/v1/erm/risk-appetite/breaches"),
      ]);

      if (dashRes.ok) {
        const json = await dashRes.json();
        setDashboard(json.data ?? []);
        setSummary(json.summary ?? null);
      }
      if (breachRes.ok) {
        const json = await breachRes.json();
        setBreaches(json.breaches ?? []);
      }
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    void fetchData();
  }, [fetchData]);

  if (loading && dashboard.length === 0) {
    return (
      <div className="flex items-center justify-center h-64">
        <Loader2 size={24} className="animate-spin text-gray-400" />
      </div>
    );
  }

  return (
    <div className="space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold text-gray-900">
            {t("riskAppetite.title")}
          </h1>
          <p className="text-sm text-gray-500 mt-1">
            {t("riskAppetite.subtitle")}
          </p>
        </div>
        <Button variant="outline" size="sm" onClick={fetchData} disabled={loading}>
          <RefreshCcw size={14} className={loading ? "animate-spin" : ""} />
        </Button>
      </div>

      {/* Summary */}
      {summary && (
        <div className="rounded-lg border border-gray-200 bg-white p-6">
          <div className="flex items-center gap-3">
            {summary.categoriesWithinAppetite === summary.totalCategories ? (
              <CheckCircle2 className="h-6 w-6 text-green-600" />
            ) : (
              <AlertTriangle className="h-6 w-6 text-red-600" />
            )}
            <span className="text-lg font-semibold text-gray-900">
              {summary.categoriesWithinAppetite} {t("riskAppetite.of")}{" "}
              {summary.totalCategories} {t("riskAppetite.withinAppetite")}
            </span>
          </div>
        </div>
      )}

      {/* Bar Chart — Appetite vs Residual */}
      <div className="rounded-lg border border-gray-200 bg-white p-6">
        <h2 className="text-base font-semibold text-gray-900 mb-4">
          {t("riskAppetite.chartTitle")}
        </h2>
        <div className="space-y-4">
          {dashboard.map((item) => (
            <div key={item.category} className="space-y-1">
              <div className="flex items-center justify-between text-sm">
                <span className="font-medium text-gray-700 capitalize">
                  {t(`riskAppetite.categories.${item.category}`)}
                </span>
                <div className="flex items-center gap-2">
                  <span className="text-xs text-gray-500">
                    {t("riskAppetite.avg")}: {item.avgResidual} / {t("riskAppetite.threshold")}: {item.appetiteThreshold}
                  </span>
                  {item.isBreached && (
                    <Badge variant="outline" className="bg-red-50 text-red-700 border-red-200 text-[10px]">
                      {item.breachCount} {t("riskAppetite.breaches")}
                    </Badge>
                  )}
                </div>
              </div>
              <div className="relative h-8 bg-gray-100 rounded-full overflow-hidden">
                {/* Residual bar */}
                <div
                  className={`absolute inset-y-0 left-0 rounded-full transition-all ${
                    item.isBreached ? "bg-red-400" : "bg-green-400"
                  }`}
                  style={{ width: `${Math.min(100, (item.avgResidual / 25) * 100)}%` }}
                />
                {/* Appetite threshold line */}
                <div
                  className="absolute inset-y-0 w-0.5 bg-red-600"
                  style={{ left: `${(item.appetiteThreshold / 25) * 100}%` }}
                />
              </div>
            </div>
          ))}
        </div>
        {dashboard.length === 0 && (
          <p className="text-sm text-gray-400 text-center py-8">
            {t("riskAppetite.noThresholds")}
          </p>
        )}
      </div>

      {/* Breach List */}
      <div className="rounded-lg border border-gray-200 bg-white p-6">
        <h2 className="text-base font-semibold text-gray-900 mb-4">
          {t("riskAppetite.breachList")}
        </h2>
        {breaches.length === 0 ? (
          <p className="text-sm text-gray-400 text-center py-8">
            {t("riskAppetite.noBreaches")}
          </p>
        ) : (
          <div className="overflow-x-auto">
            <table className="w-full text-sm">
              <thead>
                <tr className="border-b border-gray-200">
                  <th className="text-left py-2 px-3 font-medium text-gray-600">
                    {t("riskAppetite.risk")}
                  </th>
                  <th className="text-left py-2 px-3 font-medium text-gray-600">
                    {t("riskAppetite.category")}
                  </th>
                  <th className="text-right py-2 px-3 font-medium text-gray-600">
                    {t("riskAppetite.residual")}
                  </th>
                  <th className="text-right py-2 px-3 font-medium text-gray-600">
                    {t("riskAppetite.threshold")}
                  </th>
                  <th className="text-right py-2 px-3 font-medium text-gray-600">
                    {t("riskAppetite.delta")}
                  </th>
                  <th className="text-left py-2 px-3 font-medium text-gray-600">
                    {t("riskAppetite.owner")}
                  </th>
                </tr>
              </thead>
              <tbody>
                {breaches.map((b) => (
                  <tr key={b.riskId} className="border-b border-gray-100 hover:bg-gray-50">
                    <td className="py-2 px-3 font-medium text-gray-900 max-w-[200px] truncate">
                      {b.riskTitle}
                    </td>
                    <td className="py-2 px-3 text-gray-600 capitalize">{b.riskCategory}</td>
                    <td className="py-2 px-3 text-right font-mono text-red-600">
                      {b.residualScore}
                    </td>
                    <td className="py-2 px-3 text-right font-mono text-gray-500">
                      {b.appetiteThreshold}
                    </td>
                    <td className="py-2 px-3 text-right">
                      <Badge variant="outline" className="bg-red-50 text-red-700 border-red-200">
                        +{b.delta}
                      </Badge>
                    </td>
                    <td className="py-2 px-3 text-gray-600">
                      {b.ownerName ?? "-"}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  );
}
