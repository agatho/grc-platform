"use client";

import { useCallback, useEffect, useState } from "react";
import { useTranslations } from "next-intl";
import { useRouter } from "next/navigation";
import {
  Loader2,
  Upload,
  FileSpreadsheet,
  BarChart3,
  Search,
  Copy,
  Dice3,
  TrendingUp,
} from "lucide-react";

import { ModuleGate } from "@/components/module/module-gate";
import { ModuleTabNav } from "@/components/layout/module-tab-nav";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import type { AuditAnalyticsImport, AnalysisType } from "@grc/shared";

const ANALYSIS_TYPES: { value: AnalysisType; label: string; icon: React.ReactNode }[] = [
  { value: "benford", label: "Benford Analysis", icon: <BarChart3 className="h-4 w-4" /> },
  { value: "duplicate", label: "Duplicate Detection", icon: <Copy className="h-4 w-4" /> },
  { value: "outlier", label: "Outlier Detection", icon: <TrendingUp className="h-4 w-4" /> },
  { value: "sample", label: "Sampling (MUS)", icon: <Dice3 className="h-4 w-4" /> },
];

export default function AuditAnalyticsPage() {
  return (
    <ModuleGate moduleKey="audit">
      <ModuleTabNav />
      <AnalyticsInner />
    </ModuleGate>
  );
}

function AnalyticsInner() {
  const t = useTranslations("analytics");
  const router = useRouter();
  const [imports, setImports] = useState<AuditAnalyticsImport[]>([]);
  const [loading, setLoading] = useState(true);
  const [selectedImport, setSelectedImport] = useState<string | null>(null);
  const [analysisType, setAnalysisType] = useState<AnalysisType>("benford");
  const [field, setField] = useState("amount");
  const [analyzing, setAnalyzing] = useState(false);

  useEffect(() => {
    const fetchImports = async () => {
      try {
        const res = await fetch("/api/v1/audit-mgmt/analytics/imports?limit=100");
        if (res.ok) {
          const json = await res.json();
          setImports(json.data ?? []);
        }
      } finally {
        setLoading(false);
      }
    };
    void fetchImports();
  }, []);

  const runAnalysis = useCallback(async () => {
    if (!selectedImport) return;
    setAnalyzing(true);
    try {
      const config: Record<string, unknown> = { field };
      if (analysisType === "duplicate") {
        config.matchFields = [field];
        config.threshold = 85;
      }
      if (analysisType === "sample") {
        config.method = "mus";
        config.sampleSize = 30;
        config.amountField = field;
      }

      const res = await fetch(
        `/api/v1/audit-mgmt/analytics/imports/${selectedImport}/analyze`,
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ analysisType, config }),
        },
      );
      if (res.ok) {
        router.push(`/audit/analytics/${selectedImport}/results`);
      }
    } finally {
      setAnalyzing(false);
    }
  }, [selectedImport, analysisType, field, router]);

  const daysUntilExpiry = (expiresAt: string | null) => {
    if (!expiresAt) return null;
    return Math.max(0, Math.ceil((new Date(expiresAt).getTime() - Date.now()) / 86400000));
  };

  return (
    <div className="flex h-full">
      {/* Left Sidebar: Import List */}
      <div className="w-80 border-r p-4 space-y-4">
        <div className="flex items-center justify-between">
          <h2 className="font-semibold">{t("datasets")}</h2>
          <Button size="sm" variant="outline">
            <Upload className="mr-1 h-3 w-3" />
            {t("newImport")}
          </Button>
        </div>

        {loading ? (
          <Loader2 className="mx-auto h-6 w-6 animate-spin" />
        ) : (
          <div className="space-y-2">
            {imports.map((imp) => (
              <div
                key={imp.id}
                className={`cursor-pointer rounded border p-3 text-sm hover:bg-muted/25 ${
                  selectedImport === imp.id ? "border-primary bg-muted/50" : ""
                }`}
                onClick={() => setSelectedImport(imp.id)}
              >
                <div className="flex items-center gap-2">
                  <FileSpreadsheet className="h-4 w-4 text-muted-foreground" />
                  <span className="font-medium">{imp.name}</span>
                </div>
                <p className="mt-1 text-xs text-muted-foreground">
                  {imp.fileName} - {imp.rowCount} {t("rows")}
                </p>
                {imp.expiresAt && (
                  <Badge variant="outline" className="mt-1 text-xs">
                    {t("expiresIn", { days: daysUntilExpiry(imp.expiresAt) ?? 0 })}
                  </Badge>
                )}
              </div>
            ))}
            {imports.length === 0 && (
              <p className="text-center text-sm text-muted-foreground">{t("noImports")}</p>
            )}
          </div>
        )}
      </div>

      {/* Main Area: Analysis Panel */}
      <div className="flex-1 p-6 space-y-6">
        <h1 className="text-2xl font-bold">{t("title")}</h1>

        {!selectedImport ? (
          <div className="flex h-64 items-center justify-center text-muted-foreground">
            {t("selectDataset")}
          </div>
        ) : (
          <>
            {/* Analysis Selection */}
            <Card>
              <CardHeader>
                <CardTitle>{t("selectAnalysis")}</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="grid grid-cols-2 gap-3 lg:grid-cols-4">
                  {ANALYSIS_TYPES.map((at) => (
                    <button
                      key={at.value}
                      className={`rounded border p-3 text-left text-sm hover:bg-muted/25 ${
                        analysisType === at.value ? "border-primary bg-primary/10" : ""
                      }`}
                      onClick={() => setAnalysisType(at.value)}
                    >
                      <div className="flex items-center gap-2">
                        {at.icon}
                        <span className="font-medium">{at.label}</span>
                      </div>
                    </button>
                  ))}
                </div>

                <div className="space-y-2">
                  <Label>{t("fieldName")}</Label>
                  <Input
                    value={field}
                    onChange={(e) => setField(e.target.value)}
                    placeholder={t("fieldPlaceholder")}
                  />
                </div>

                <Button onClick={runAnalysis} disabled={analyzing}>
                  {analyzing ? (
                    <Loader2 className="mr-2 h-4 w-4 animate-spin" />
                  ) : (
                    <Search className="mr-2 h-4 w-4" />
                  )}
                  {t("runAnalysis")}
                </Button>
              </CardContent>
            </Card>
          </>
        )}
      </div>
    </div>
  );
}
