# ARCTOS GRC Platform — Caddy Reverse Proxy Template
# Automatisches HTTPS via Let's Encrypt
#
# VERWENDUNG:
# Option A: DOMAIN Umgebungsvariable setzen → DOMAIN=arctos.firma.de caddy start
# Option B: setup-hetzner.sh nutzt dieses Template und ersetzt __DOMAIN__

{$DOMAIN:__DOMAIN__} {
  # Block TRACE/TRACK methods
  @trace method TRACE TRACK
  respond @trace 405

  reverse_proxy localhost:3000

  # Security Headers
  header {
    Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
    X-XSS-Protection "1; mode=block"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'"
    Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    -Server
    -X-Powered-By
  }

  # Kompression
  encode gzip zstd

  # JSON Logging (fuer fail2ban)
  log {
    output file /var/log/caddy/arctos.log {
      roll_size 10mb
      roll_keep 5
    }
    format json
  }
}
