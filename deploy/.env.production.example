# ============================================================================
# ARCTOS GRC Platform — Production Environment
# Kopieren nach /opt/arctos/.env und Werte anpassen
# ============================================================================

# ── Domain ─────────────────────────────────────────────────
# Ihre Domain (DNS A-Record muss auf den Server zeigen)
DOMAIN=arctos.ihrefirma.de
AUTH_URL=https://arctos.ihrefirma.de

# ── Datenbank ──────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_DB_PW
DATABASE_URL=postgresql://grc:CHANGE_ME_DB_PW@postgres:5432/grc_platform

# ── Auth (automatisch generiert bei setup.sh) ──────────────
AUTH_SECRET=CHANGE_ME_AUTH_SECRET
AUTH_TRUST_HOST=true

# ── Whistleblowing Verschluesselung ───────────────────────
WB_ENCRYPTION_KEY=CHANGE_ME_WB_KEY

# ── Connector Credential Verschluesselung (Pflicht bei aktiven Connectors) ──
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WICHTIG: Schluessel-Rotation invalidiert alle gespeicherten Credential-Rows.
# Anderen Wert als WB_ENCRYPTION_KEY verwenden.
CONNECTOR_ENCRYPTION_KEY=CHANGE_ME_CONNECTOR_KEY

# ── Application-Secret Verschluesselung (Pflicht bei SSO/OIDC + OAuth-Connectors) ──
# Verschluesselt sso_config.oidc_client_secret und
# connector_credential.refresh_token at rest (v1-Envelope).
# Generate: openssl rand -base64 32
# Anderen Wert als WB_/CONNECTOR_ENCRYPTION_KEY verwenden.
# Rotation: alten Key als SECRET_ENCRYPTION_KEY_PREVIOUS setzen,
# scripts/encrypt-connector-secrets.mjs laufen lassen, dann entfernen.
SECRET_ENCRYPTION_KEY=CHANGE_ME_SECRET_KEY
# SECRET_ENCRYPTION_KEY_PREVIOUS=

# ── Worker Cron ────────────────────────────────────────────
CRON_SECRET=CHANGE_ME_CRON

# ── Seed bei erstem Start ──────────────────────────────────
RUN_SEEDS=true

# ── E-Mail (optional, fuer Einladungen per Mail) ──────────
EMAIL_ENABLED=false
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# ── KI-Features (optional) ────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# ── Sonstiges ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
REDIS_URL=redis://redis:6379

# ============================================================
# Impressum (§ 5 DDG) — PFLICHT für jeden Server, der publik
# erreichbar ist. Bei Verstoß drohen Abmahnungen + Bußgelder.
# /legal/imprint zeigt die Werte. Nicht-konfigurierte Felder
# rendern als "[bitte konfigurieren]" mit Hinweisbanner.
# ============================================================
IMPRINT_COMPANY_NAME=
IMPRINT_LEGAL_FORM=
IMPRINT_STREET=
IMPRINT_CITY=
IMPRINT_COUNTRY=Deutschland
IMPRINT_EMAIL=
IMPRINT_PHONE=
IMPRINT_MANAGING_DIRECTORS=
IMPRINT_REGISTER_COURT=
IMPRINT_REGISTER_NUMBER=
IMPRINT_VAT_ID=
IMPRINT_BUSINESS_ID=
IMPRINT_SUPERVISORY_AUTHORITY=
IMPRINT_PROFESSIONAL_TITLE=
IMPRINT_RESPONSIBLE_FOR_CONTENT=
IMPRINT_SHOW_EU_DISPUTE_NOTICE=true
IMPRINT_ADDITIONAL_TEXT=

# ── Datenschutz (DSGVO Art. 13/14) ─────────────────────────
# Default-Werte werden aus Impressum übernommen wenn leer.
PRIVACY_CONTROLLER_NAME=
PRIVACY_CONTROLLER_ADDRESS=
PRIVACY_DPO_NAME=
PRIVACY_DPO_EMAIL=
PRIVACY_HOSTING_LOCATION=Hetzner Online GmbH, Deutschland
PRIVACY_SUPERVISORY_AUTHORITY=
PRIVACY_ADDITIONAL_TEXT=

# ── Testserver-Vollaktivierung (MinIO + ClamAV Sidecars) ─────────────
# MinIO (S3-Backend fuer DMS-Files; Sidecar aus docker-compose.production.yml)
# MINIO_ROOT_PASSWORD wird von update-all.sh auto-generiert.
# MINIO_ROOT_USER=arctos
# STORAGE_BACKEND=s3
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=arctos-dms
# S3_ACCESS_KEY_ID=arctos            # = MINIO_ROOT_USER
# S3_SECRET_ACCESS_KEY=<wert von MINIO_ROOT_PASSWORD>
# S3_FORCE_PATH_STYLE=1
# ClamAV-Upload-Scan (Sidecar; braucht ~1-1.5 GB RAM)
# CLAMAV_HOST=clamav
# CLAMAV_PORT=3310
