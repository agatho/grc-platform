# ============================================================================
# ARCTOS GRC Platform — Environment Configuration
#
# Copy this file to .env and fill in the values:
#   cp .env.sample .env
#
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================

# ── Database ────────────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_use_a_strong_password

# ── Authentication (REQUIRED) ──────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=CHANGE_ME_generate_with_command_above
AUTH_URL=http://localhost:3000

# ── Whistleblowing Encryption (REQUIRED) ───────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WB_ENCRYPTION_KEY=CHANGE_ME_generate_with_command_above

# ── Connector Credential Encryption (REQUIRED when connectors are active) ──
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use a DIFFERENT value than WB_ENCRYPTION_KEY.
CONNECTOR_ENCRYPTION_KEY=CHANGE_ME_generate_with_command_above

# ── Application-Secret Encryption (REQUIRED for SSO/OIDC + OAuth connectors) ──
# Encrypts sso_config.oidc_client_secret and connector_credential.refresh_token
# at rest. Generate: openssl rand -base64 32
# Use a DIFFERENT value than WB_/CONNECTOR_ENCRYPTION_KEY.
SECRET_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
# Rotation fallback (only set while rotating, then remove):
# SECRET_ENCRYPTION_KEY_PREVIOUS=

# ── Internal Security ──────────────────────────────────────────
CRON_SECRET=CHANGE_ME_any_random_string
REDIS_PASSWORD=CHANGE_ME_any_random_string

# ── Application ────────────────────────────────────────────────
PORT=3000
IMAGE_TAG=latest

# ── First Run ──────────────────────────────────────────────────
# Set to true on first startup to populate demo data.
# Change to false after first run.
RUN_SEEDS=true

# ── AI Features (optional) ─────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Email (optional) ───────────────────────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# EMAIL_ENABLED=true

# ── Azure AD SSO (optional) ────────────────────────────────────
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
