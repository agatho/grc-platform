# Database (ADR-005)
# Production: use grc_app (non-superuser, RLS enforced)
# Development: grc (superuser) is fine for migrations + seeds
DATABASE_URL=postgresql://grc_app:grc_app_dev_password@localhost:5432/grc_platform
# Superuser URL for migrations only (not used by the app at runtime)
DATABASE_URL_ADMIN=postgresql://grc:grc_dev_password@localhost:5432/grc_platform

# Auth.js (ADR-007 rev.1)
AUTH_SECRET=generate-a-random-secret-here
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Azure AD / Microsoft Entra ID SSO (S1-07, optional — uncomment and fill to enable)
# Register an app in Azure Portal > Microsoft Entra ID > App registrations.
# Set the redirect URI to: {AUTH_URL}/api/auth/callback/microsoft-entra-id
# Required scopes: openid, profile, email
# AZURE_AD_CLIENT_ID=<Application (client) ID from Azure Portal>
# AZURE_AD_CLIENT_SECRET=<Client secret value from Certificates & secrets>
# AZURE_AD_TENANT_ID=<Directory (tenant) ID — restricts login to your organization>

# AI Providers (ADR-008) — configure one or more, first available is used as default
# Set AI_DEFAULT_PROVIDER to override (claude_cli | claude_api | openai | gemini | ollama | lmstudio)
AI_DEFAULT_PROVIDER=claude_cli

# Claude via CLI (uses your Claude subscription — no API key needed)
# Requires: claude CLI installed and authenticated (claude.ai login)
# Set CLAUDE_CLI_PATH if not in PATH (default: "claude")
# CLAUDE_CLI_PATH=/home/grctool/.local/bin/claude
# CLAUDE_CLI_ENABLED=true

# Claude API (Anthropic) — separate pay-per-token billing
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, GPT-4-turbo)
# OPENAI_API_KEY=sk-...

# Google Gemini (free tier: 15 RPM, 1M tokens/day)
# GOOGLE_AI_API_KEY=AIza...

# Ollama (local models, GDPR-safe) — for privacy-sensitive data
# Personal data is automatically routed to Ollama when available
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_ENABLED=true

# LM Studio (local models with GUI, OpenAI-compatible API, GDPR-safe)
# Fallback for privacy routing when Ollama is not available
# LMSTUDIO_BASE_URL=http://localhost:1234
# LMSTUDIO_ENABLED=true
# LMSTUDIO_DEFAULT_MODEL=local-model

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Worker Cron Jobs
CRON_SECRET=arctos-cron-secret-change-in-production

# Whistleblowing Encryption (REQUIRED for Sprint 12)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WB_ENCRYPTION_KEY=generate-a-64-char-hex-key-here-do-not-use-in-production

# Connector Credential Encryption (REQUIRED when connectors are active)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: rotating this key invalidates every stored credential row.
# Use a different value than WB_ENCRYPTION_KEY.
CONNECTOR_ENCRYPTION_KEY=generate-a-64-char-hex-key-here-do-not-use-in-production

# Application-Secret Encryption at rest (REQUIRED when SSO/OIDC or
# connector OAuth refresh tokens are used). Encrypts single-column
# secrets (sso_config.oidc_client_secret, connector_credential.
# refresh_token) via packages/shared/src/secret-crypto.ts.
# Generate with: openssl rand -base64 32   (hex also accepted)
# Use a different value than WB_/CONNECTOR_ENCRYPTION_KEY.
SECRET_ENCRYPTION_KEY=generate-a-32-byte-base64-key-here-do-not-use-in-production
# Key rotation: set the OLD key here, deploy, run
# scripts/encrypt-connector-secrets.mjs (re-seals under the new key),
# then remove it again.
# SECRET_ENCRYPTION_KEY_PREVIOUS=

# Email (Resend)
RESEND_API_KEY=re_test_placeholder
RESEND_FROM_EMAIL=noreply@arctos.local
RESEND_FROM_NAME=ARCTOS GRC Platform
EMAIL_ENABLED=false

# ──────────────────────────────────────────────────────────────
# Backfilled by dep-config-hygiene-2026-05-23 §quick-win #1 —
# operator-facing keys that code reads but .env.example didn't list.
# ──────────────────────────────────────────────────────────────

# Auth.js public base URL — REQUIRED in production. SSO/SCIM/SAML
# routes all use this for callback URLs. Without it, OIDC callbacks
# default to localhost (caught by getBaseUrl() helper). Alias of
# AUTH_URL; both are accepted.
# NEXTAUTH_URL=https://arctos.charliehund.de

# Rate-limit + cache backing store. Without it, rateLimit() falls
# back to per-pod in-memory buckets (NOT shared across instances —
# multi-pod deploys lose enforcement). Required for production.
# REDIS_URL=redis://localhost:6379

# File-upload base directory for documents (download endpoint reads
# from here). Defaults to <cwd>/../../uploads/documents.
# UPLOAD_DIR=/var/lib/arctos/uploads

# Webhook outbound safety (#SEC-HIGH-SSRF protections)
# Allow webhooks to reach private hostnames/IPs — DEV ONLY. Default
# false; setting to "1" disables the checkResolvedHostIsPublic guard.
WEBHOOK_ALLOW_PRIVATE_HOSTS=0
# Allow webhook URLs over plain http://. Default false (https only).
WEBHOOK_ALLOW_HTTP=0

# Worker observability
# Log level for the structured NDJSON logger (apps/web + apps/worker).
# trace|debug|info|warn|error|fatal — default "info".
# ARCTOS_LOG_LEVEL=info
# Service name in log lines + traces. Defaults to "arctos-web" /
# "arctos-worker" per package; override only for staging/canary tags.
# ARCTOS_SERVICE=arctos-web

# Build metadata (server- + client-side). CI sets these at image
# build time; leave blank in dev.
# APP_VERSION=0.1.0-alpha
# BUILD_TIME=2026-05-23T12:00:00Z
# GIT_BRANCH=main
# GIT_SHA=abcdef123
# NEXT_PUBLIC_BUILD_TIME=2026-05-23T12:00:00Z
# NEXT_PUBLIC_GIT_BRANCH=main
# NEXT_PUBLIC_GIT_SHA=abcdef123

# Public portal base URL for supplier DD portal links in email
# templates. Falls back to NEXTAUTH_URL if unset.
# PORTAL_BASE_URL=https://portal.arctos.charliehund.de

# Regulatory feed sources (regulatory-change-detection cron). All
# optional — the cron skips a source if the URL isn't set.
# BSI_FEED_URL=https://www.bsi.bund.de/SiteGlobals/Functions/RSSFeed/...
# BAFIN_FEED_URL=https://www.bafin.de/SharedDocs/RSS/EN/Feeds/...
# EURLEX_FEED_URL=https://eur-lex.europa.eu/EN/legal-content/...
# NVD API key — optional; without it the CVE-feed cron uses the
# anonymous rate limit (5 req/30s instead of 50 req/30s).
# NVD_API_KEY=

# Server port (apps/web). Defaults to 3000.
# PORT=3000
